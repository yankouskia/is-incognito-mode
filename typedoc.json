{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs-site",
  "name": "is-incognito-mode",
  "readme": "README.md",
  "tsconfig": "tsconfig.json",
  "plugin": ["typedoc-material-theme"],
  "themeColor": "#3f51b5",
  "includeVersion": true,
  "categorizeByGroup": true,
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "json5",
    "yaml",
    "tsx",
    "typescript",
    "mermaid"
  ],
  "navigationLinks": {
    "Live demo": "https://yankouskia.github.io/is-incognito-mode/demo/",
    "GitHub": "https://github.com/yankouskia/is-incognito-mode",
    "npm": "https://www.npmjs.com/package/is-incognito-mode"
  },
  "sidebarLinks": {
    "Live demo": "https://yankouskia.github.io/is-incognito-mode/demo/",
    "Changelog": "https://github.com/yankouskia/is-incognito-mode/blob/master/CHANGELOG.md"
  },
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  }
}
